#include <iostream>
#include <vector>
#include <functional>

using namespace std;

vector<int> transform(
    const vector<int>& data,
    function<int(int)> func)
{
    vector<int> result;

    for (int x : data)
    {
        result.push_back(func(x));
    }

    return result;
}

int main()
{
    vector<int> data = {1, 2, 3, 4};

    vector<int> result =
        transform(
            data,
            [](int x)
            {
                return x * 2;
            }
        );

    for (int x : result)
    {
        cout << x << " ";
    }

    return 0;
}
